{
  "name": "@botpress/runtime",
  "version": "1.18.2",
  "description": "Lightweight runtime library for ADK-based Botpress agents",
  "keywords": [
    "adk",
    "agent",
    "ai",
    "botpress",
    "chatbot",
    "conversational-ai",
    "runtime"
  ],
  "license": "MIT",
  "author": "Botpress",
  "repository": {
    "type": "git",
    "url": "https://github.com/botpress/adk"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/library.d.ts",
      "import": "./dist/library.js"
    },
    "./library": {
      "types": "./dist/library.d.ts",
      "import": "./dist/library.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./definition": {
      "types": "./dist/definition.d.ts",
      "import": "./dist/definition.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js"
    }
  },
  "scripts": {
    "build": "tsc && bun esbuild.ts",
    "build:watch": "tsc --watch",
    "watch": "bun esbuild.ts --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build",
    "test": "bun test",
    "v": "tsc --version",
    "check:type": "tsc --noEmit"
  },
  "dependencies": {
    "@botpress/client": "~1.39.0",
    "@botpress/cognitive": "~0.5.2",
    "@botpress/sdk": "~6.4.4",
    "@botpress/zai": "~2.6.15",
    "@bpinternal/const": "~0.7.0",
    "@bpinternal/thicktoken": "~2.0.0",
    "@bpinternal/zui": "~2.1.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^2.2.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/instrumentation-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "axios": "^1.13.2",
    "bytes": "^3.1.2",
    "dedent": "^1.7.1",
    "fast-safe-stringify": "^2.1.1",
    "fast-xml-parser": "^5.3.3",
    "glob": "^11.1.0",
    "llmz": "~0.0.69",
    "lodash": "^4.17.21",
    "ms": "^2.1.3",
    "object-sizeof": "^2.6.5",
    "p-limit": "^7.3.0",
    "pretty-bytes": "^7.0.1",
    "ulid": "^3.0.2",
    "undici": "^7.16.0"
  },
  "peerDependencies": {
    "@types/react": ">=18",
    "typescript": ">=4.5.0"
  },
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.13"
}
