{
  "name": "@botpress/sdk",
  "version": "6.4.5",
  "description": "Botpress SDK",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "repository": {
    "url": "https://github.com/botpress/botpress"
  },
  "scripts": {
    "check:type": "tsc -p ./tsconfig.json --noEmit",
    "build:type": "tsc -p ./tsconfig.package.json --emitDeclarationOnly --declaration",
    "build:browser": "ts-node -T ./build.ts --browser",
    "build:node": "ts-node -T ./build.ts --node",
    "build": "pnpm build:type && pnpm build:node && pnpm build:browser",
    "test": "vitest --run"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@botpress/client": "1.40.0",
    "browser-or-node": "^2.1.1",
    "semver": "^7.3.8"
  },
  "devDependencies": {
    "@types/semver": "^7.3.11",
    "esbuild": "^0.25.10",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "tsup": "^8.0.2"
  },
  "peerDependencies": {
    "@bpinternal/zui": "^2.1.1",
    "esbuild": "^0.16.12"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.12.4"
}
